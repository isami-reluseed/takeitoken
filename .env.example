# ------------------------------------------------------------
# LINE (LIFF)
# ------------------------------------------------------------
LINE_AUTH_MODE=dummy
LIFF_ID=TODO_SET_LIFF_ID
LINE_LOGIN_CHANNEL_ID=TODO_SET_LINE_LOGIN_CHANNEL_ID
LINE_LOGIN_CHANNEL_SECRET=TODO_SET_LINE_LOGIN_CHANNEL_SECRET
LINE_ID_TOKEN_VERIFY_URL=https://api.line.me/oauth2/v2.1/verify
DUMMY_LINE_USER_ID=U1234567890DUMMY
