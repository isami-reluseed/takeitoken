# TODO: LIFF_ID / LINE_LOGIN_CHANNEL_ID / LINE_LOGIN_CHANNEL_SECRET を実値に置き換える。

# ------------------------------------------------------------
# Kaia Kairos Testnet
# ------------------------------------------------------------
KAIA_NETWORK=kairos
KAIA_CHAIN_ID=1001
KAIA_RPC_URL=https://public-en-kairos.node.kaia.io
KAIA_MINT_MODE=dummy
KAIA_OPERATOR_PRIVATE_KEY=TODO_SET_KAIA_OPERATOR_PRIVATE_KEY
