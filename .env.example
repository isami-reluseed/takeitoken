# TODO: KAIA_OPERATOR_PRIVATE_KEY / KIP17_CONTRACT_ADDRESS / KIP7_CONTRACT_ADDRESS を実値に置き換える。

# ------------------------------------------------------------
# Fixed campaign (single campaign only)
# ------------------------------------------------------------
CAMPAIGN_NAME=TAKEI TOKEN POC Campaign
CLAIM_START_AT=2026-03-01T00:00:00.000Z
CLAIM_END_AT=2026-12-31T23:59:59.000Z
COIN_AMOUNT=10000
